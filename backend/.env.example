# Supabase Credentials & Database Connections
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_PROJECT_REF.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SERVICE_ROLE_API_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=documents

# S3 Protocol Configuration (Supabase Storage Compatible)
S3_ENDPOINT=https://YOUR_PROJECT_REF.storage.supabase.co/storage/v1/s3
ENDPOINT_URL=https://YOUR_PROJECT_REF.storage.supabase.co/storage/v1/s3
S3_REGION=eu-west-1
REGION=eu-west-1
S3_ACCESS_KEY_ID=your-access-key-id
ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=documents

# Storage Provider (supabase or s3)
STORAGE_PROVIDER=supabase

# Admin Page Login Credentials
ADMIN_PASSWORD=change-me
ADMIN_TOKEN=change-me-too

# Frontend & Backend URLs
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-backend.onrender.com

# Email Credentials
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@example.com
EMAIL_PASSWORD=your-app-password
ADMIN_EMAIL=you@example.com

# Server Port
PORT=3000
