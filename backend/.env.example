# --- Supabase Postgres ---
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_PROJECT_REF.pooler.supabase.com:6543/postgres

# --- Supabase Storage ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # NEVER expose this in the frontend
SUPABASE_STORAGE_BUCKET=documents                 # create this as a PRIVATE bucket

# --- S3 Protocol Configuration (Supabase Storage compatible) ---
S3_ENDPOINT=https://stsvsfcsttkxfdtrhoce.storage.supabase.co/storage/v1/s3
S3_REGION=eu-west-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=documents
STORAGE_PROVIDER=supabase  # Options: 'supabase' (default) or 's3'

# --- Admin auth ---
ADMIN_PASSWORD=change-me
ADMIN_TOKEN=change-me-too

# --- CORS: your deployed Vercel frontend URL(s), comma-separated ---
FRONTEND_URL=https://your-app.vercel.app

# --- Email (optional) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@example.com
EMAIL_PASSWORD=your-app-password
ADMIN_EMAIL=you@example.com

PORT=3000
